# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wwm

# Firebase (download service account JSON, put path here)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Paystack ( Ghana - use test keys for dev )
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxx

# App URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Platform config (optional - defaults used if not set)
PLATFORM_COMMISSION_PCT=15
PLATFORM_SERVICE_FEE_PCT=2.5
VENDOR_MATCHING_MODE=manual
BOOKING_BUFFER_MINUTES=60
VENDOR_SLA_RESPONSE_HOURS=24

# Notifications (optional - stub without these)
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=
